# HTTP 服务端口配置
PORT=3000

# ================================
# LLM (大模型) 配置区
# ================================
# 配置你要使用的大语言模型提供商 API 地址 
# 比如如果用 OpenAI 格式，填 https://api.openai.com/v1/chat/completions
# 如果用 DeepSeek，填 https://api.deepseek.com/v1/chat/completions
# 如果用 硅基流动，填 https://api.siliconflow.cn/v1/chat/completions
LLM_ENDPOINT=

# 你的 API Key
LLM_API_KEY=

# 使用的模型名称，一般如 gemini-3-flash-preview 等
LLM_MODEL=


# ================================
# TTS (文字转语音) 配置区
# ================================
# 填入你部署的本地 IndexTTS2 服务的请求地址
# 或是如果你使用的是第三方平台（硅基流动/Azure），填入对应的高级调用地址
TTS_ENDPOINT=http://localhost:5000/tts

# （可选）如果有 TTS 的账号密码或 API-Key，我们可以在 tts.js 里面添加读取
TTS_API_KEY=your_tts_api_key_here
