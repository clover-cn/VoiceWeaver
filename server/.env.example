# HTTP 服务端口配置
PORT=3000

# ================================
# LLM (大模型) 配置区
# ================================
# 配置LLM模型提供商 API 地址 
# 如 OpenAI 格式 https://api.openai.com/v1/chat/completions
LLM_ENDPOINT=

# 你的 API Key
LLM_API_KEY=

# 使用的模型名称，一般如 gemini-3-flash-preview 等
LLM_MODEL=


# ================================
# TTS (文字转语音) 配置区
# ================================
# 填入你部署的本地 IndexTTS2 服务的请求地址
# 或是如果你使用的是第三方平台（硅基流动/Azure），填入对应的高级调用地址
TTS_ENDPOINT=http://localhost:5000/tts

# （可选）如果有 TTS 的账号密码或 API-Key，我们可以在 tts.js 里面添加读取
TTS_API_KEY=your_tts_api_key_here

# 目前支持的 TTS 模型厂家：siliconflow, indextts2, mimoTTS
TTS_DEFAULT_PROVIDER=siliconflow
# 如果是siliconflow必须指定使用的语音模型
AUDIO_MODEL="fnlp/MOSS-TTSD-v0.5"

# 小米 MimoTTS 配置，仅当 TTS_DEFAULT_PROVIDER=mimoTTS 时生效
MIMO_API_KEY=
MIMO_TTS_ENDPOINT=https://api.xiaomimimo.com/v1/chat/completions
MIMO_TTS_MODEL=mimo-v2.5-tts-voiceclone
# 语音风格提示，用于调整生成的语音风格, 例如“保持样本声线，减少夸张表演，语气清楚、平稳、贴近真实说话。”；该自然语言指令只对 MimoTTS 生效。
MIMO_TTS_STYLE_PROMPT=保持样本声线，减少夸张表演，语气清楚、平稳、贴近真实说话。
MIMO_TTS_SAMPLE_RATE=24000
MIMO_TTS_TIMEOUT_MS=120000

# ==========================================
# 预扫描模型配置
# ==========================================
# 预扫描轻量级模型 (推荐使用成本低、长上下文能力强的模型，如 deepseek-chat, gpt-4o-mini, glm-4-flash)
PRESCAN_LLM_MODEL="deepseek-chat"
# 默认预扫描的章节数，0为关闭
PRESCAN_CHAPTER_COUNT=10
# 听书功能：播放时后台预生成的后续章节数量，0为关闭
LISTEN_PREFETCH_COUNT=1

# ==========================================
# 听书 Pipeline 超时配置（毫秒）
# ==========================================
# 0 表示不限时，仅依赖前端取消信号（AbortController）来中断请求。
# 长章节的 LLM 流式输出可能耗时较长，建议保持默认值 0。
LISTEN_BOOK_LLM_PARSE_TIMEOUT_MS=0
LISTEN_BOOK_PRESCAN_TIMEOUT_MS=0
LISTEN_BOOK_TTS_TIMEOUT_MS=0
