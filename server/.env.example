# HTTP 服务端口配置
PORT=3000

# ================================
# LLM (大模型) 配置区
# ================================
# 配置 LLM 模型提供商 API 地址，例如 OpenAI 兼容格式：
# https://api.openai.com/v1/chat/completions
LLM_ENDPOINT=

# LLM API Key
LLM_API_KEY=

# 使用的模型名称，例如 deepseek-chat、glm-4-flash 等
LLM_MODEL=

# ================================
# TTS (文字转语音) 配置区
# ================================
# 目前支持的 TTS 模型厂家：siliconflow, indextts2, mimoTTS
TTS_DEFAULT_PROVIDER=siliconflow

# SiliconFlow 配置，仅当 TTS_DEFAULT_PROVIDER=siliconflow 时生效
TTS_ENDPOINT=https://api.siliconflow.cn/v1/audio/speech
SILICONFLOW_API_KEY=
# SiliconFlow 使用的语音模型
AUDIO_MODEL=fnlp/MOSS-TTSD-v0.5

# IndexTTS2 配置，仅当 TTS_DEFAULT_PROVIDER=indextts2 时生效
# 注意：Docker 容器内的 localhost / 127.0.0.1 指容器自身，不是宿主机。
# 裸机运行后端和 IndexTTS2 时可用：
# TTS_ENDPOINT=http://127.0.0.1:8000/api/tts/upload
# 后端在 Docker 中、IndexTTS2 在宿主机运行时使用：
# TTS_ENDPOINT=http://host.docker.internal:8000/api/tts/upload
# 后端和 IndexTTS2 在同一个 docker compose 网络内时使用服务名，例如：
# TTS_ENDPOINT=http://indextts2:8000/api/tts/upload

# 小米 MimoTTS 配置，仅当 TTS_DEFAULT_PROVIDER=mimoTTS 时生效
MIMO_API_KEY=
MIMO_TTS_ENDPOINT=https://api.xiaomimimo.com/v1/chat/completions
MIMO_TTS_MODEL=mimo-v2.5-tts-voiceclone
# 语音风格提示，用于调整生成的语音风格；该自然语言指令只对 MimoTTS 生效。
MIMO_TTS_STYLE_PROMPT=保持样本声线，减少夸张表演，语气清楚、平稳、贴近真实说话。
MIMO_TTS_SAMPLE_RATE=24000
MIMO_TTS_TIMEOUT_MS=120000

# ==========================================
# 预扫描模型配置
# ==========================================
# 预扫描轻量级模型，推荐使用成本低、长上下文能力强的模型，如 deepseek-chat、gpt-4o-mini、glm-4-flash。
PRESCAN_LLM_MODEL=deepseek-chat
# 默认预扫描的章节数，0 为关闭。
PRESCAN_CHAPTER_COUNT=10
# 听书功能：播放时后台预生成的后续章节数量，0 为关闭。
LISTEN_PREFETCH_COUNT=1

# ==========================================
# 听书 Pipeline 超时配置（毫秒）
# ==========================================
# 0 表示不限时，仅依赖前端取消信号（AbortController）来中断请求。
# 长章节的 LLM 流式输出可能耗时较长，建议保持默认值 0。
LISTEN_BOOK_LLM_PARSE_TIMEOUT_MS=0
LISTEN_BOOK_PRESCAN_TIMEOUT_MS=0
LISTEN_BOOK_TTS_TIMEOUT_MS=0
